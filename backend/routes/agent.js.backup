// routes/agent.js
import express from 'express';
import rateLimit from 'express-rate-limit';
import { completeProduct, completeArticle, completeBatch } from '../controllers/agentController.js';
import authMiddleware from '../middleware/auth.js';

const router = express.Router();

const agentLimiter = rateLimit({
  windowMs: 60 * 60 * 1000,
  max: 20,
  message: { success: false, error: 'تعداد درخواست‌ها محدود است، لطفاً بعداً تلاش کنید' },
  standardHeaders: true,
  legacyHeaders: false,
});

router.post('/complete-product', authMiddleware, agentLimiter, completeProduct);
router.post('/complete-article', authMiddleware, agentLimiter, completeArticle);
router.post('/complete-batch', authMiddleware, agentLimiter, completeBatch);

export default router;
